{
  "name": "codeprep-vscode",
  "displayName": "CodePrep",
  "description": "Select files via GUI and prepare context for LLMs.",
  "version": "0.5.0",
  "publisher": "codeprep",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeprep/codeprep.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeprep-helper",
          "title": "CodePrep",
          "icon": "$(library)"
        }
      ]
    },
    "views": {
      "codeprep-helper": [
        {
          "id": "codeprep.fileTree",
          "name": "File Explorer",
          "icon": "$(library)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "codeprep.fileTree",
        "contents": "CodePrep へようこそ。\n生成対象のファイルをツリーから選択してください。ワークスペース全体のファイルを一括で含めることも可能です。\n[すべて選択](command:codeprep.selectAll)\n[設定を開く](command:codeprep.openSettings)",
        "when": "codeprep.selectionEmpty"
      }
    ],
    "commands": [
      {
        "command": "codeprep.selectionMenu",
        "title": "Selection Actions...",
        "icon": "$(list-selection)"
      },
      {
        "command": "codeprep.presetMenu",
        "title": "Preset Actions...",
        "icon": "$(library)"
      },
      {
        "command": "codeprep.openSettings",
        "title": "Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "codeprep.selectAll",
        "title": "Select All",
        "icon": "$(check-all)"
      },
      {
        "command": "codeprep.clearAll",
        "title": "Clear All",
        "icon": "$(clear-all)"
      },
      {
        "command": "codeprep.invertSelection",
        "title": "Invert Selection"
      },
      {
        "command": "codeprep.generate",
        "title": "Generate & Copy",
        "icon": "$(run)"
      },
      {
        "command": "codeprep.selectGitDiff",
        "title": "Select Modified Files",
        "icon": "$(git-compare)"
      },
      {
        "command": "codeprep.selectPrompt",
        "title": "Select Prompt",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "codeprep.addToSelection",
        "title": "Add to CodePrep"
      },
      {
        "command": "codeprep.savePreset",
        "title": "Save Preset",
        "icon": "$(save)"
      },
      {
        "command": "codeprep.loadPreset",
        "title": "Load Preset",
        "icon": "$(folder-opened)"
      },
      {
        "command": "codeprep.exportPresets",
        "title": "Export Presets",
        "icon": "$(export)"
      },
      {
        "command": "codeprep.importPresets",
        "title": "Import Presets",
        "icon": "$(import)"
      },
      {
        "command": "codeprep.deletePrompt",
        "title": "Delete Prompt",
        "icon": "$(trash)"
      },
      {
        "command": "codeprep.refreshTree",
        "title": "Refresh Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "codeprep.gitMenu",
        "title": "Git Actions",
        "icon": "$(git-branch)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codeprep.refreshTree",
          "when": "view == codeprep.fileTree && codeprep.showRefreshTree",
          "group": "navigation@0"
        },
        {
          "command": "codeprep.openSettings",
          "when": "view == codeprep.fileTree",
          "group": "navigation@0"
        },
        {
          "command": "codeprep.selectionMenu",
          "when": "view == codeprep.fileTree",
          "group": "navigation@1"
        },
        {
          "command": "codeprep.gitMenu",
          "when": "view == codeprep.fileTree && codeprep.showGitMenu",
          "group": "navigation@2"
        },
        {
          "command": "codeprep.selectPrompt",
          "when": "view == codeprep.fileTree && codeprep.showSelectPrompt",
          "group": "navigation@3"
        },
        {
          "command": "codeprep.generate",
          "when": "view == codeprep.fileTree && codeprep.showGenerate",
          "group": "navigation@4"
        },
        {
          "command": "codeprep.presetMenu",
          "when": "view == codeprep.fileTree",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "codeprep.generate",
          "group": "inline"
        }
      ],
      "explorer/context": [
        {
          "command": "codeprep.addToSelection",
          "group": "7_modification",
          "when": "resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "title": "CodePrep Settings",
      "properties": {
        "codeprep.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/out/**",
            "**/dist/**"
          ],
          "description": "Patterns to exclude from the tree view and selection."
        },
        "codeprep.customPrompts": {
          "type": "object",
          "default": {
            "✨ 1. 新機能実装 (Implement Feature)": "## 依頼\n以下のプロジェクト構造とコードを読み取り、新しい機能 [機能名をここに記述] を実装してください。\n\n## 構造\n{{tree}}\n\n## 制約事項\n- 既存の設計パターン（DDD/クリーンアーキテクチャ等）を遵守してください。\n- 型安全性を確保し、anyの使用を避けてください。\n- 実装に関連するユニットテストも併せて提案してください。\n\n## 言語設定\n回答は日本語で行ってください。",
            "🛠️ 2. リファクタリング (Refactor)": "## 依頼\n提供するコードのリファクタリング案を提示してください。\n\n## 構造\n{{tree}}\n\n## 観点\n- 可読性の向上（命名、関数の分割）\n- 計算量の最適化\n- 疎結合・高凝集な設計への改善\n- 重複コードの排除\n\n## 形式\n修正後のコードだけでなく、なぜそのように変更すべきかの理由を添えてください。",
            "🐛 3. デバッグ・問題解析 (Bug Fix)": "## 状況\n以下のコードで [問題の内容を記述] という不具合が発生しています。\n\n## 構造\n{{tree}}\n\n## 調査依頼\n- 原因の特定と、その解説\n- 修正プログラムの提示\n- 再発防止のためのテストケースの提案\n\n## 補足\n実行日時: {{datetime}}\n環境: {{language}}",
            "🧪 4. テストコード生成 (Unit Test)": "## 依頼\n以下のソースコードに対するユニットテストを記述してください。\n\n## 構造\n{{tree}}\n\n## 要件\n- テストフレームワーク: [Vitest/Jest等を記述]\n- 正常系だけでなく、境界値や異常系のテストを含めてください。\n- モックが必要な場合は、その作り方も含めて提示してください。\n- カバレッジを意識した構成にしてください。",
            "📝 5. コードレビュー (Review)": "## 依頼\nあなたはシニアフルスタックエンジニアです。提出されたコードを厳しく、かつ建設的にレビューしてください。\n\n## 構造\n{{tree}}\n\n## チェックリスト\n- バグの可能性はないか\n- セキュリティ上の脆弱性（インジェクション、機密情報の露出など）はないか\n- パフォーマンス上の懸念はないか\n- 言語ごとのベストプラクティスに従っているか"
          },
          "description": "Define your custom prompts here as key-value pairs (Label: Prompt Content)."
        },
        "codeprep.visibleButtons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "codeprep.selectAll",
              "codeprep.clearAll",
              "codeprep.generate",
              "codeprep.selectGitDiff",
              "codeprep.selectPrompt",
              "codeprep.savePreset",
              "codeprep.loadPreset",
              "codeprep.invertSelection",
              "codeprep.exportPresets",
              "codeprep.importPresets",
              "codeprep.gitMenu"
            ]
          },
          "default": [
            "codeprep.refreshTree",
            "codeprep.selectAll",
            "codeprep.selectGitDiff",
            "codeprep.gitMenu",
            "codeprep.selectPrompt",
            "codeprep.generate",
            "codeprep.clearAll"
          ],
          "description": "Select which buttons are visible in the view title bar (Max 6 recommended by VSCode UI)."
        },
        "codeprep.outputFormat": {
          "type": "string",
          "enum": [
            "markdown",
            "xml",
            "json"
          ],
          "default": "markdown",
          "description": "Select the output format for the generated content."
        },
        "codeprep.useNativeEngine": {
          "type": "boolean",
          "default": true,
          "description": "Use the built-in engine for faster processing."
        },
        "codeprep.outputFilePath": {
          "type": "string",
          "default": "codeprep-output.txt",
          "description": "The default filename for the generated output."
        },
        "codeprep.tokenLimit": {
          "type": "integer",
          "default": 100000,
          "description": "Display a warning when the estimated token count exceeds this limit."
        },
        "codeprep.maxFileSizeKB": {
          "type": "integer",
          "default": 500,
          "description": "巨大ファイル・ガードの閾値 (KB)。このサイズを超えるファイルは、内容が省略されます。"
        },
        "codeprep.nativeEngine.removeComments": {
          "type": "boolean",
          "default": false,
          "description": "(Native Engine) Remove comments from the source code."
        },
        "codeprep.nativeEngine.includeEmptyLines": {
          "type": "boolean",
          "default": true,
          "description": "(Native Engine) Include empty lines in the output."
        },
        "codeprep.autoRefreshTree": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh the file tree when files are created, changed, or deleted."
        },
        "codeprep.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "^node_modules/",
            "^\\.git/",
            "\\.vsix$"
          ],
          "description": "List of regex patterns to exclude from the file tree. (e.g. ^node_modules/)"
        },
        "codeprep.enablePreview": {
          "type": "boolean",
          "default": false,
          "description": "Show a preview in a new editor tab before saving or copying."
        },
        "codeprep.openAfterGenerate": {
          "type": "boolean",
          "default": true,
          "description": "生成完了後に、内容を新しいエディタタブで開きます。"
        },
        "codeprep.openAfterGitAction": {
          "type": "boolean",
          "default": true,
          "description": "Gitアクション（コミットプロンプト生成など）の後に、内容を新しいエディタタブで開きます。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts --cache",
    "test": "node ./out/test/runTest.js",
    "test:e2e": "node ./out/test/runTest.js",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.84.0",
    "@vitest/coverage-v8": "latest",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^8.56.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^4.9.4",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1"
  }
}