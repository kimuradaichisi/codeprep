{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": [
      "ES2020"
    ],
    "sourceMap": true,
    "rootDir": ".",           // 1. "src" から "." に変更（プロジェクト全体をルートにする）
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true, 
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*",
    "scripts/**/*"            // 2. scripts を含める
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "vitest.config.ts",
    "fix_native_engine.py"
    // "scripts"              // 3. ここから削除する
  ]
}